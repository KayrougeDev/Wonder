<owo-ui xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/wisp-forest/owo-lib/refs/heads/26.1/owo-ui.xsd">
    <components>
        <flow-layout direction="horizontal">
            <children>
                <label>
                    <text>Player's menu</text>
                    <shadow>true</shadow>
                    <positioning type="relative">50,3</positioning>
                </label>

                <flow-layout direction="horizontal" id="box-container">
                    <children>
                        <flow-layout direction="vertical" id="runes-container">
                            <children>
                                <label>
                                    <text translate="true">container.playermenu.runes</text>
                                </label>
                                <grid-layout rows="1" columns="5" id="equipped-runes-grid">
                                    <children>
                                    </children>
                                    <surface>
                                        <panel dark="false" />
                                    </surface>
                                    <sizing>
                                        <horizontal method="fill">100</horizontal>
                                        <vertical method="fill">15</vertical>
                                    </sizing>
                                    <vertical-alignment>center</vertical-alignment>
                                    <horizontal-alignment>center</horizontal-alignment>
                                    <margins><bottom>2</bottom></margins>
                                </grid-layout>
                                <label id="player-inventory-title">
                                    <text translate="true">container.inventory</text>
                                </label>
                                <grid-layout rows="6" columns="6" id="player-inventory-grid">
                                    <children>
                                    </children>
                                    <surface>
                                        <panel dark="false" />
                                    </surface>
                                    <sizing>
                                        <horizontal method="fill">100</horizontal>
                                        <vertical method="fill">74</vertical>
                                    </sizing>
                                    <vertical-alignment>center</vertical-alignment>
                                    <horizontal-alignment>center</horizontal-alignment>
                                    <padding><top>3</top><left>1</left></padding>
                                </grid-layout>
                            </children>
                            <margins>
                                <all>10</all>
                                <right>5</right>
                            </margins>
                            <sizing>
                                <horizontal method="fill">30</horizontal>
                                <vertical method="fill">80</vertical>
                            </sizing>

                            <padding><top>5</top></padding>
                            <horizontal-alignment>center</horizontal-alignment>

                        </flow-layout>

                        <flow-layout direction="vertical">
                            <children>
                                <label id="player-data">
                                    <text>Some data</text>
                                    <shadow>true</shadow>
                                    <color>gold</color>
                                </label>


                            </children>
                            <surface>
                                <panel />
                            </surface>

                            <margins>
                                <all>10</all>
                                <left>5</left>
                            </margins>
                            <padding><top>5</top></padding>

                            <vertical-alignment>top</vertical-alignment>
                            <horizontal-alignment>center</horizontal-alignment>

                            <sizing>
                                <horizontal method="fill">45</horizontal>
                                <vertical method="fill">80</vertical>
                            </sizing>
                        </flow-layout>

                    </children>
                    <vertical-alignment>center</vertical-alignment>
                    <horizontal-alignment>center</horizontal-alignment>

                    <surface>
                        <panel dark="true"/>
                    </surface>
                </flow-layout>

            </children>

            <vertical-alignment>center</vertical-alignment>
            <horizontal-alignment>center</horizontal-alignment>

            <surface>
                <vanilla-translucent />
            </surface>
        </flow-layout>
    </components>
</owo-ui>